{
  "expo": {
    "name": "Režije",
    "slug": "racuni",
    "version": "1.0.10",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {

      "backgroundColor": "#2D3F51"
    },
        "statusBar": {
      "barStyle": "dark-content",
      "backgroundColor": "#ffffff",
      "translucent": false
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.cehaosk.racuni"
    },
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Računi to save photos to your gallery.",
          "savePhotosPermission": "Allow Računi to save photos to your gallery.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow Računi to use your camera to photograph bills."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Računi to use your camera to scan QR codes."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2a9752b0-84e4-4a7d-9f6c-5318b11b5ffa"
      }
    }
  }
}